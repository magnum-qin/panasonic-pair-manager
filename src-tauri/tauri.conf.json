{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Panasonic Pair Manager",
  "version": "0.1.0",
  "identifier": "com.codex.panasonic-pair-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Panasonic Pair Manager",
        "width": 1440,
        "height": 900,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
